<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>edit you chat</title>
</head>
<body>
        <p> Edit your chat :<%= Chat._id %></p>
        <p> this chat was sent from <b><%= Chat.from %></b> to <b><%= Chat.to %></b></p>

        <form method="POST" action="/chats/<%= Chat._id%>?_method=PUT">
                   <textarea name="msg" rows="10" cols="30"> <%= Chat.message %></textarea><br>
                   <button> Edit</button>
        </form>
</body>
</html>